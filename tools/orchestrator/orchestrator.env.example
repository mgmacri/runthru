# Orchestrator config — copy to orchestrator.env and edit.
# orchestrator.env is gitignored (it holds your private ntfy topic).

# --- Notifications (ntfy.sh) ---
# Your private topic. Anyone who knows it can read/post, so keep it secret-ish.
# Subscribe to this exact topic in the ntfy mobile app (Android/iOS) or at
# https://ntfy.sh/<topic> in a browser.
NTFY_TOPIC="runthru-CHANGEME"
NTFY_SERVER="https://ntfy.sh"
# Control topic the Approve/Hold buttons POST back to (defaults to <topic>-ctl).
NTFY_CONTROL_TOPIC="runthru-CHANGEME-ctl"
APPROVAL_TIMEOUT=3600
APPROVAL_POLL_INTERVAL=15
# Optional send-only Slack mirror (incoming webhook URL); leave blank to skip.
SLACK_WEBHOOK_URL=""

# --- Models / roles ---
# Who writes the code first: "claude" or "codex". The reviewer is always the OTHER one.
AUTHOR="claude"

# Max remediation rounds before the loop gives up and escalates to you.
MAX_REVIEW_ROUNDS=4

# --- Paths ---
GOAL_DOC="doc/goals/google-drive-next-milestone-plan.md"

# --- Permissions / autonomy (tune for your comfort + sandbox) ---
# Claude headless permission mode: default | acceptEdits | plan | bypassPermissions
CLAUDE_PERM="acceptEdits"
# Extra args appended to `codex exec` (e.g. "--full-auto" if your config requires it).
CODEX_EXEC_ARGS=""

# Set to 1 to let the loop create a local commit on a work branch after review PASSes.
# It NEVER pushes. Default 0 = stop at the manual-test gate with changes uncommitted.
AUTO_COMMIT=0
